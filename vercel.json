{
  "framework": "vite",
  "buildCommand": "node scripts/vercel-build.mjs",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/:match*",
      "destination": "https://youthful-sockeye-531.convex.site/api/v1/:match*"
    },
    {
      "source": "/claim/:match*",
      "destination": "/"
    },
    {
      "source": "/event-review/:match*",
      "destination": "/"
    },
    {
      "source": "/ai-town/:match*",
      "destination": "/:match*"
    }
  ]
}
